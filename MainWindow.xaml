<Window x:Class="PoeFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoeFixer"
        mc:Ignorable="d"
        Title="xdx_Smoother POE 2" Height="700" Width="900" 
        Icon="/cigar.ico" Background="#1A1C2E" Foreground="White"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#242842" CornerRadius="5" Padding="2" Margin="0,0,0,15" BorderBrush="#343A50" BorderThickness="1">
            <Grid Height="35">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PathTextBox" 
                         Grid.Column="0"
                         Text="Vui lòng chọn đường dẫn đến file GGPK" 
                         IsReadOnly="True" 
                         Background="Transparent" 
                         Foreground="White" 
                         BorderThickness="0" 
                         VerticalContentAlignment="Center" 
                         Padding="10,0" 
                         FontSize="13"
                         FontFamily="Segoe UI"/>

                <Button Grid.Column="1" 
                        Content="Chọn" 
                        Click="SelectGGPK"
                        Background="#3B82F6" 
                        Foreground="White" 
                        BorderThickness="0" 
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,3,3,0"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#242842" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Môi trường &amp; Hiệu ứng" Foreground="#94A3B8" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <CheckBox x:Name="zoomEnabled" Content="Zoom" Foreground="White" VerticalAlignment="Center"/>
                        <Slider x:Name="zoomSlider" Width="120" Margin="15,0,10,0" 
                                Maximum="5" Minimum="1" Value="1" 
                                TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding ElementName=zoomSlider, Path=Value, StringFormat={}{0:F2}}" VerticalAlignment="Center" Foreground="#3B82F6"/>
                    </StackPanel>

                    <CheckBox x:Name="removeParticles" Content="Remove Particles (Experimental)" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="revealMap" Content="Reveal Map" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeFog" Content="Remove Fog" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeShadows" Content="Remove Sun Shadows" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeLight" Content="Remove Lights" Margin="0,5" Foreground="White"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <CheckBox x:Name="colourMods" Content="Color mod" Foreground="White" VerticalAlignment="Center"/>
                        <Button Click="OpenColorSettings_Click" 
                                Content="⚙️" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Foreground="#3B82F6" 
                                Cursor="Hand"
                                FontSize="14"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="Cấu hình danh sách Mod"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Gameplay &amp; Performance" Foreground="#94A3B8" FontWeight="Bold" Margin="0,0,0,10"/>
                    <CheckBox x:Name="removeLoadingScreen" Content="Invisible Loading Screen" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeCorpses" Content="Remove Corpses" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeShatter" Content="Remove Shatter" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeBloom" Content="Remove Bloom" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeAllPet" Content="Remove All Pets" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeItem" Content="Remove All Item Effects" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeDelirium" Content="Remove Delirium Effects" Margin="0,5" Foreground="White"/>
                    <CheckBox x:Name="removeEffect" Content="Remove All Effects" Margin="0,5" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="Extractor" Click="ExtractVanillaAssets" Height="40" Margin="0,5" Background="#334155" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Restore" Click="RestoreExtractedAssets" Height="40" Margin="0,5" Background="#334155" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Separator Background="#343A50" Margin="0,15"/>

                    <Button x:Name="PatchButton" Click="PatchGGPK" Width="150" Height="50" Background="#F1F5F9" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Path x:Name="LoadingSpinner" 
                                  Data="M12,4V2A10,10 0 0,0 2,12H4A8,8 0 0,1 12,4Z" 
                                  Fill="#1A1C2E" Width="18" Height="18" RenderTransformOrigin="0.5,0.5"
                                  Visibility="Collapsed" Margin="0,0,10,0">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerTransform" Angle="0" />
                                </Path.RenderTransform>
                            </Path>
                            <TextBlock x:Name="ButtonText" Text="PATCH" VerticalAlignment="Center" Foreground="#1A1C2E" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>

                        <Button.Resources>
                            <Storyboard x:Key="RotationAnimation">
                                <DoubleAnimation Storyboard.TargetName="SpinnerTransform"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:1"
                                                 RepeatBehavior="Forever" />
                            </Storyboard>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#0F172A" CornerRadius="5" Margin="0,15,0,0" BorderBrush="#343A50" BorderThickness="1">
            <RichTextBox x:Name="Console" IsReadOnly="True" 
                         Background="Transparent" Foreground="#CBD5E1" 
                         BorderThickness="0" VerticalScrollBarVisibility="Auto" 
                         Padding="12" FontFamily="Consolas" FontSize="12">
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type Paragraph}">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </Border>
    </Grid>
</Window>